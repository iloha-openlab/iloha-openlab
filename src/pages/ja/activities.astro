---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDictionary } from "../../i18n";

const lang = "ja";
const t = getDictionary(lang);
const act = t.activities;
---

<BaseLayout
  lang={lang}
  title={`${act.title} | ${t.company.nameEn}`}
  description={act.lead}
>
  <div class="activities-container">
    <h1>{act.title}</h1>
    
    <!-- セクション A: リード文 -->
    <section class="lead-section">
      <p>{act.lead}</p>
    </section>

    <!-- セクション B: プロフィール概要 -->
    <section class="profile-section">
      <h2>{act.profile.title}</h2>
      <div class="profile-grid">
        <div class="profile-table">
          <table>
            <tr><th>氏名</th><td>{act.profile.name}</td></tr>
            <tr><th>役職（法人）</th><td>{act.profile.position}</td></tr>
            <tr><th>コミュニティ役職</th><td>{act.profile.communityPosition}</td></tr>
            <tr><th>主な専門領域</th><td>{act.profile.specialties}</td></tr>
          </table>
        </div>
        <div class="profile-links">
          <h3>外部リンク</h3>
          <ul>
            {act.profile.links.map(link => (
              <li>
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {link.name} ↗
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- セクション C: コミュニティ役職 -->
    <section class="community-section">
      <h2>{act.communities.title}</h2>
      <div class="item-list">
        {act.communities.items.map(item => (
          <div class="item-card">
            <h3>{item.name}</h3>
            <p class="role"><strong>役職: {item.role}</strong></p>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- セクション D: OSSプロジェクト -->
    <section class="projects-section">
      <h2>{act.projects.title}</h2>
      <div class="table-container">
        <table class="project-table">
          <thead>
            <tr>
              <th>プロジェクト名</th>
              <th>役割</th>
              <th>概要</th>
              <th>リンク</th>
            </tr>
          </thead>
          <tbody>
            {act.projects.items.map(item => (
              <tr>
                <td><strong>{item.name}</strong></td>
                <td>{item.role}</td>
                <td>{item.description}</td>
                <td><a href={item.url} target="_blank" rel="noopener noreferrer">Link ↗</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- セクション E: コントリビューション実績 -->
    <section class="contributions-section">
      <h2>{act.contributions.title}</h2>
      <p>{act.contributions.text}</p>
    </section>

    <!-- セクション F: 主な受賞・表彰 -->
    <section class="awards-section">
      <h2>{act.awards.title}</h2>
      <div class="item-list">
        {act.awards.items.map(item => (
          <div class="item-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 追加: 以前からあった項目など -->
    <section class="legacy-section">
      <h2>{act.legacyItems.title}</h2>
      <div class="legacy-grid">
        {act.legacyItems.items.map(item => (
          <div class="legacy-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
            <a href={item.url} target="_blank" rel="noopener noreferrer">詳細 ↗</a>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .activities-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 0;
  }
  
  h1 {
    border-bottom: 2px solid #333;
    padding-bottom: 1rem;
    margin-bottom: 2rem;
  }

  h2 {
    border-left: 5px solid #0066cc;
    padding-left: 1rem;
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }

  section {
    margin-bottom: 3rem;
  }

  .lead-section p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #444;
  }

  .profile-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    background: #f9f9f9;
    padding: 1.5rem;
    border-radius: 8px;
  }

  .profile-table table {
    width: 100%;
    border-collapse: collapse;
  }

  .profile-table th, .profile-table td {
    text-align: left;
    padding: 0.75rem 0;
    border-bottom: 1px solid #eee;
  }

  .profile-table th {
    width: 30%;
    color: #666;
    font-weight: normal;
  }

  .profile-links h3 {
    margin-top: 0;
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  .profile-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .profile-links li {
    margin-bottom: 0.5rem;
  }

  .profile-links a {
    color: #0066cc;
    text-decoration: none;
  }

  .profile-links a:hover {
    text-decoration: underline;
  }

  .item-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .item-card {
    border: 1px solid #eee;
    padding: 1.5rem;
    border-radius: 8px;
    background-color: #fff;
  }

  .item-card h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.2rem;
  }

  .item-card .role {
    color: #0066cc;
    margin-bottom: 0.5rem;
  }

  .table-container {
    overflow-x: auto;
  }

  .project-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .project-table th, .project-table td {
    border: 1px solid #eee;
    padding: 0.75rem;
    text-align: left;
  }

  .project-table th {
    background-color: #f5f5f5;
    font-weight: bold;
  }

  .project-table a {
    color: #0066cc;
    text-decoration: none;
  }

  .legacy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .legacy-card {
    border: 1px solid #eee;
    padding: 1.2rem;
    border-radius: 8px;
    background-color: #fcfcfc;
  }

  .legacy-card h3 {
    font-size: 1.1rem;
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .legacy-card p {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 1rem;
  }

  .legacy-card a {
    color: #0066cc;
    font-weight: bold;
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .profile-grid {
      grid-template-columns: 1fr;
    }
    .project-table th, .project-table td {
      padding: 0.5rem;
    }
  }
</style>
