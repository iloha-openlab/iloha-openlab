---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDictionary } from "../../i18n";
import { getCollection } from "astro:content";

const lang = "en";
const t = getDictionary(lang);

const newsEntries = await getCollection("news", ({ data }) => {
  return data.lang === lang;
});

newsEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentNews = newsEntries.slice(0, 3);
---

<BaseLayout
  lang={lang}
  title={`${t.company.nameEn} | Official Website`}
  description={`Official website of ${t.company.nameEn}`}
>
  <div class="logo-container">
    <img src="/images/logo-horizontal.svg" alt="ILOHA OpenLab Logo" class="logo" width="500" height="120" />
  </div>
  <h1>{t.company.nameEn}</h1>
  <p class="tagline"><strong>{t.company.tagline}</strong></p>

  <nav>
    <a href="/en/">{t.nav.home}</a> |
    <a href="/en/news/">{t.nav.news}</a> |
    <a href="/en/products/">{t.nav.products}</a> |
    <a href="/en/privacy/">{t.nav.privacy}</a> |
    <a href="/en/logo-policy/">{t.nav.logoPolicy}</a> |
    <a href="/ja/">日本語</a>
  </nav>

  <section class="mission">
    <p>{t.company.mission}</p>
  </section>

  <section class="news-excerpt">
    <h2>{t.news.title}</h2>
    <ul class="news-list">
      {recentNews.map(entry => (
        <li>
          <time datetime={entry.data.date.toISOString()}>
            {entry.data.date.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <a href={`/en/news/${entry.id.replace(/\.en\.md$/, '')}/`}>{entry.data.title}</a>
        </li>
      ))}
    </ul>
    <p><a href="/en/news/">View all news...</a></p>
  </section>

  <section class="products">
    <h2>{t.products.title}</h2>
    <div class="product-summary">
      {t.products.categories.map(category => (
        <div class="product-category-excerpt">
          <h3>{category.name}</h3>
          <p>{category.description}</p>
          <a href={`/en/products/#${category.id}`}>Read more...</a>
        </div>
      ))}
    </div>
    <p><a href="/en/products/">All products and services...</a></p>
  </section>

  <section class="brand-story">
    <h2>Brand Story</h2>
    <p>{t.company.brandStory}</p>
  </section>

  <section>
    <h2>Company Overview</h2>
    <table>
      <tr><th>Company Name</th><td>{t.company.nameEn}</td></tr>
      <tr><th>Japanese Name</th><td>{t.company.nameJa}</td></tr>
      <tr><th>Legal Form</th><td>{t.company.legalForm}</td></tr>
      <tr><th>Representative</th><td>{t.company.representative}</td></tr>
      <tr><th>Head Office</th><td>{t.company.headOffice}</td></tr>
      <tr><th>Fiscal Year</th><td>{t.company.fiscalYear}</td></tr>
      <tr><th>Japan Corporate Number</th><td>{t.company.id}</td></tr>
      <tr><th>D-U-N-S® Number</th><td>{t.company.duns}</td></tr>
      <tr><th>Business Category</th><td>{t.company.businessCategory}</td></tr>
      <tr><th>Industrial Classification</th><td>{t.company.industrialClassification}</td></tr>
      <tr><th>Main Business</th><td>{t.company.mainBusiness}</td></tr>
      <tr>
        <th>Business Activities</th>
        <td>
          <ul>
            {t.business.map(item => <li>{item}</li>)}
          </ul>
        </td>
      </tr>
      <tr><th>LinkedIn</th><td><a href={t.company.linkedin} target="_blank" rel="noopener noreferrer"><img src="/images/logo-horizontal-150.png" alt="ILOHA OpenLab Logo"/>↗️</a></td></tr>
      <tr><th>Contact</th><td>{t.company.contact}</td></tr>
    </table>
  </section>
</BaseLayout>

<style>
  .news-list {
    list-style: none;
    padding: 0;
  }
  .news-list li {
    margin-bottom: 0.5rem;
  }
  .news-list time {
    color: #666;
    font-size: 0.9rem;
    margin-right: 1rem;
  }
  .product-category-excerpt {
    margin-bottom: 1.5rem;
  }
  .product-category-excerpt h3 {
    margin-bottom: 0.5rem;
  }
</style>
