---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getDictionary } from "../../i18n";
const t = getDictionary("en");
---

<BaseLayout
  lang="en"
  title={`${t.company.nameEn} | Official Website`}
  description={`Official website of ${t.company.nameEn}`}
>
  <h1>{t.company.nameEn}</h1>

  <nav>
    <a href="/en/">Home</a> |
    <a href="/en/privacy/">Privacy Policy</a> |
    <a href="/ja/">日本語</a>
  </nav>

  <section>
    <h2>Company Overview</h2>
    <table>
      <tr><th>Company Name</th><td>{t.company.nameEn}</td></tr>
      <tr><th>Japanese Name</th><td>{t.company.nameJa}</td></tr>
      <tr><th>Legal Form</th><td>{t.company.legalForm}</td></tr>
      <tr><th>Head Office</th><td>{t.company.headOffice}</td></tr>
      <tr><th>Fiscal Year</th><td>{t.company.fiscalYear}</td></tr>
      <tr>
        <th>Business Activities</th>
        <td>
          <ul>
            {t.business.map(item => <li>{item}</li>)}
          </ul>
        </td>
      </tr>
      <tr><th>Contact</th><td>{t.company.contact}</td></tr>
    </table>
  </section>
</BaseLayout>
