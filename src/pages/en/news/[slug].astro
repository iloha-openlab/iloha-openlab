---
import { Image } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getDictionary } from "../../../i18n";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const newsEntries = await getCollection("news", ({ data }) => data.lang === "en");
  return newsEntries.map(entry => {
    return {
      params: { slug: entry.id.replace(/\.en\.md$/, '') }, props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const lang = "en";
const t = getDictionary(lang);
---

<BaseLayout
  lang={lang}
  title={`${entry.data.title} | ${t.company.nameEn}`}
  description={entry.data.description}
>
  <article>
    <h1>{entry.data.title}</h1>
    <time datetime={entry.data.date.toISOString()}>
      {entry.data.date.toLocaleDateString(lang, { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
    {entry.data.image && (
      typeof entry.data.image === "string" ? (
        <img src={entry.data.image} alt="" class="hero-image" />
      ) : (
        <Image src={entry.data.image} alt="" class="hero-image" />
      )
    )}
    {entry.data.storeUrl && (
      <div class="store-cta">
        <a href={entry.data.storeUrl} target="_blank" rel="noopener noreferrer" class="store-button">
          Buy in Store ↗
        </a>
      </div>
    )}
    <div class="content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  time {
    color: #666;
    display: block;
    margin-bottom: 2rem;
  }
  .store-cta {
    margin: 1.5rem 0;
  }
  .store-button {
    display: inline-block;
    background: #ff5e00;
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    font-size: 1rem;
    transition: background 0.2s;
  }
  .store-button:hover {
    background: #e65500;
  }
  .hero-image {
    width: auto;
    max-width: 100%;
    max-height: 200px;
    height: auto;
    margin-bottom: 2rem;
  }
  .content {
    line-height: 1.6;
  }
</style>
